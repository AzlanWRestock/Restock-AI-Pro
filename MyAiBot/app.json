{
  "expo": {
    "name": "Restock AI",
    "slug": "MyAiBot",
    "version": "1.0.0",
    "privacy": "public", 
    "owner": "azlanahmed2012",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myaibot",
    "userInterfaceStyle": "dark", 
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.azlan.restockai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.azlan.restockai"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "description": "Advanced AI assistant for the Restock ecosystem.",
      "backgroundColor": "#121212",
      "themeColor": "#ff66b2"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5acf60ee-3579-47d0-8184-10e22dc6c467"
      }
    }
  }
}